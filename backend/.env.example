# Backend .env.example
# Copy this to .env and fill in your values

# Application
DEBUG=false
HOST=0.0.0.0
PORT=8000
APP_NAME="Credit Risk Assessment API"

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/credit_risk
SQLALCHEMY_ECHO=false

# Security
SECRET_KEY=your-very-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS & Hosts
ALLOWED_HOSTS=localhost,127.0.0.1,your-api-domain.com
CORS_ORIGINS=http://localhost:3000,https://your-frontend-domain.com

# Models
MODELS_DIR=./ml_models
PRIMARY_MODEL=xgboost

# Feature Flags
ENABLE_BATCH_PROCESSING=true
ENABLE_SHAP_EXPLANATIONS=true
ENABLE_AUDIT_LOGGING=true
ENABLE_GOVERNANCE=true

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_PER_HOUR=5000

# Batch Processing
BATCH_MAX_SIZE=10000
BATCH_TIMEOUT_SECONDS=300
BATCH_WORKER_COUNT=4

# File Storage
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=100

# Cloud Storage (R2/S3)
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET_NAME=credit-risk-results

# Logging
LOG_LEVEL=INFO
LOG_FILE=./app.log

# Monitoring
SENTRY_DSN=
DATADOG_API_KEY=

# Thresholds
LOW_RISK_THRESHOLD=0.25
MEDIUM_RISK_THRESHOLD=0.65

# Model Retraining
ENABLE_AUTO_RETRAINING=false
RETRAINING_INTERVAL_DAYS=30
MIN_SAMPLES_FOR_RETRAINING=1000

# Features
ENABLE_FEATURE_ENGINEERING=true
FEATURE_ENGINEERING_VERSION=1.0

# Cache
ENABLE_CACHE=true
CACHE_TTL_SECONDS=3600
