# Frontend .env.example
# Copy to .env and set the API URL

# API Configuration
REACT_APP_API_URL=http://localhost:8000/api/v1
REACT_APP_API_TIMEOUT=30000

# Application
REACT_APP_APP_NAME=Credit Risk Assessment
REACT_APP_VERSION=2.0.0

# Environment
REACT_APP_ENVIRONMENT=development

# Feature Flags
REACT_APP_ENABLE_ANALYTICS=false
REACT_APP_ENABLE_SENTRY=false

# Sentry (Error Tracking)
REACT_APP_SENTRY_DSN=

# Analytics
REACT_APP_GOOGLE_ANALYTICS_ID=

# Timeouts
REACT_APP_API_TIMEOUT_MS=30000
REACT_APP_SESSION_TIMEOUT_MS=1800000

# UI Settings
REACT_APP_ROWS_PER_PAGE=20
REACT_APP_MAX_FILE_UPLOAD_MB=100

# Branding
REACT_APP_COMPANY_NAME=Your Company
REACT_APP_COMPANY_LOGO_URL=/logo.png

# Map & Location
REACT_APP_GOOGLE_MAPS_API_KEY=
REACT_APP_MAP_CENTER_LAT=40.7128
REACT_APP_MAP_CENTER_LNG=-74.0060
REACT_APP_MAP_DEFAULT_ZOOM=10
